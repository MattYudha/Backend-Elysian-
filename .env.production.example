# Server
PORT=7777
ENV=production
LOG_LEVEL=info
GRACEFUL_SHUTDOWN_TIMEOUT=30s

# Database — GANTI password di bawah!
DB_HOST=postgres
DB_PORT=5432
DB_USER=elysian
DB_PASSWORD=GANTI_PASSWORD_KUAT_DISINI
DB_NAME=elysian
DB_SSL_MODE=disable

# Connection Pooling
PG_BOUNCER_URL=
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10

# Redis — GANTI password di bawah!
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_REDIS_PASSWORD_DISINI
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT — GANTI secret key di bawah! (generate: openssl rand -base64 32)
JWT_SECRET=GANTI_JWT_SECRET_DISINI
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h
JWT_ISSUER=elysian-flow

# RabbitMQ (opsional, sesuaikan jika dipakai)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_NAME=workflow_executions
RABBITMQ_WORKER_COUNT=5

# ML Service (sesuaikan URL jika ada)
ML_SERVICE_URL=http://localhost:5000
ML_SERVICE_TIMEOUT=30s
ML_SERVICE_RETRY_COUNT=3
ML_SERVICE_RETRY_DELAY=1s

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS — GANTI dengan domain Vercel frontend Anda!
CORS_ALLOWED_ORIGINS=https://DOMAIN-VERCEL-ANDA.vercel.app,https://domain-kustom-anda.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true

MAX_UPLOAD_SIZE=10MB
ALLOWED_FILE_TYPES=.pdf,.csv,.json,.txt
